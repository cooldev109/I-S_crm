# ----------------------------------------------------------------------------
# Root env example. Copy to .env in /api and /web as needed (see each workspace).
# Never commit a real .env. Keep this file updated with every new variable.
# ----------------------------------------------------------------------------

# --- API: server ---
NODE_ENV=development
API_PORT=1109
API_BASE_URL=http://localhost:1109

# --- API: database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studio_ops?schema=public

# --- API: redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- API: auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- API: integrations (Phase 1 needs WhatsApp + OpenAI) ---
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
OPENAI_API_KEY=

# --- Web ---
VITE_API_BASE_URL=http://localhost:1109

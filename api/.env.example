# Copy to api/.env for local development.
NODE_ENV=development
API_PORT=1109
API_BASE_URL=http://localhost:1109

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studio_ops?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Web origin allowed by CORS
WEB_ORIGIN=http://localhost:1995

# Integrations — not required to boot, only when those modules are exercised
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
OPENAI_API_KEY=
